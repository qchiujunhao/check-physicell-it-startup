# Galaxy connection — provide API key OR username/password
GALAXY_BASE_URL=https://usegalaxy.org
GALAXY_API_KEY=
GALAXY_USERNAME=
GALAXY_PASSWORD=

# PhysiCell tool ID on Galaxy
PHYSICELL_TOOL_ID=toolshed.g2.bx.psu.edu/repos/rheiland/physicell_studio/interactive_tool_pcstudio/0.7

# Monitoring settings
STARTUP_TIMEOUT_SECONDS=600
STARTUP_EXPECTED_SECONDS=120
HISTORY_NAME=PhysiCell Monitor
OUTPUT_DIR=output
